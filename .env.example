SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

DB_ENGINE=postgresql
DB_NAME=fasoim_db
DB_USER=fasoim_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=FasoIM <your_email@example.com>
EMAIL_TIMEOUT=20
FASOIM_LOGIN_URL=http://127.0.0.1:3000/connexion
FASOIM_PUBLIC_URL=http://127.0.0.1:3000

# Notifications sans table
NOTIFICATIONS_ENABLED=True
NOTIFICATIONS_ENABLE_DURING_TESTS=False
NOTIFICATIONS_LOCK_SECONDS=300
NOTIFICATIONS_TENTATIVE_TTL_SECONDS=600
NOTIFICATIONS_DEDUP_SUCCESS_SECONDS=31536000
NOTIFICATIONS_BATCH_SIZE=200
NOTIFICATIONS_MAX_RELAIS_ETABLISSEMENT=3
NOTIFICATIONS_RETRY_DELAY_SECONDS=60

# Redis / Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/1
CELERY_TASK_TIME_LIMIT=1800

# Alertes et incidents
INCIDENTS_TAILLE_LOT_SCAN=500
INCIDENTS_MAX_ALERTES_CREEES_PAR_REGLE=500
INCIDENTS_SCAN_LOCK_SECONDS=2100
INCIDENTS_SCAN_DEBOUNCE_SECONDS=30
INCIDENTS_CONTROLES_CIBLES_ACTIFS=True

# Documents, attestations et publications
DOCUMENTS_PUBLIC_RATE_LIMIT=20
DOCUMENTS_PUBLIC_RATE_WINDOW_SECONDS=900
DOCUMENTS_PROGRESS_TTL_SECONDS=86400
DOCUMENTS_DETECTION_READY_MINUTES=10
